DEBUG=true

# PostgreSQL Database (for LangGraph checkpointer)
POSTGRES_HOST=192.168.1.252
POSTGRES_PORT=5432
POSTGRES_USER=aiagent
POSTGRES_PASSWORD=NO_KEY
POSTGRES_DB=aiagent
LANGGRAPH_SCHEMA=langgraph
TEST_SCHEMA=test
TEST_LANGGRAPH_SCHEMA=test_langgraph
TEST_MEMORY_SCHEMA=test_memories

# Qdrant Vector Database (for RAG)
QDRANT_HOST=192.168.1.252
QDRANT_PORT=6333
QDRANT_TEST_L0_COLLECTION=test_l0_conversations
QDRANT_TEST_L1_COLLECTION=test_l1_memories

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://192.168.1.251:3001
EVOLUTION_API_KEY=NO_KEY

# i18n locale (default: zh_HK)
LANG_LOCALE=zh_HK

ROUTING_LLM_ENDPOINT=http://192.168.1.252:8604/v1
ROUTING_LLM_API_KEY=NO_KEY
ROUTING_LLM_MODEL=qwen3.5-4b

SYS_ACT_LLM_ENDPOINT=http://192.168.1.252:8601/v1
SYS_ACT_LLM_API_KEY=NO_KEY
SYS_ACT_LLM_MODEL=qwen3.6-35b-a3b

# TDAI Memory
# Every editable MemoryConfig field has an explicit default here.
# Memory PostgreSQL 連線 URL；如有設定會覆蓋 POSTGRES_* 組合出來的 URL。
MEMORY_POSTGRES_URL=postgresql://localhost:5432/tdai_memory
# Memory PostgreSQL schema 名稱；Alembic memory tables 會放在此 schema。
MEMORY_SCHEMA=memories
# Qdrant 連線 URL；如有設定會覆蓋 QDRANT_HOST/QDRANT_PORT 組合出來的 URL。
MEMORY_QDRANT_URL=http://localhost:6333
# Qdrant L0 raw conversation vector collection 名稱。
QDRANT_L0_COLLECTION=l0_conversations
# Qdrant L1 structured memory vector collection 名稱。
QDRANT_L1_COLLECTION=l1_memories
# Memory 檔案資料目錄；用於 conversations JSONL、persona、scene blocks、offload 等。
MEMORY_DATA_DIR=./tdai_data

# TDAI Memory embedding
# Embedding API endpoint，需相容 OpenAI embeddings API。
EMBEDDING_LLM_ENDPOINT=https://api.openai.com/v1
# Embedding API key；本地服務可留空或按服務要求填寫。
EMBEDDING_LLM_API_KEY=
# Embedding model 名稱。
EMBEDDING_LLM_MODEL=text-embedding-3-small
# Embedding vector 維度；0 代表使用 model 預設維度。
EMBEDDING_DIMENSION=0
# 單次 embedding 輸入最大字元數，超出會截斷。
MEMORY_EMBEDDING_MAX_INPUT_CHARS=5000
# Embedding API timeout，單位毫秒。
MEMORY_EMBEDDING_TIMEOUT_MS=10000

# TDAI Memory LLM
# TDAI memory pipeline 使用的 LLM endpoint，需相容 OpenAI chat completions API。
TDAI_LLM_ENDPOINT=https://api.openai.com/v1
# TDAI memory pipeline 使用的 LLM API key。
TDAI_LLM_API_KEY=
# TDAI memory pipeline 使用的預設 LLM model。
TDAI_LLM_MODEL=gpt-4o
# TDAI memory pipeline 單次 LLM 回應最大 token 數。
MEMORY_LLM_MAX_TOKENS=4096
# TDAI memory pipeline LLM request timeout，單位毫秒。
MEMORY_LLM_TIMEOUT_MS=120000

# TDAI Memory capture
# 是否啟用 completed turn capture 設定。
MEMORY_CAPTURE_ENABLED=true
# L0/L1 retention 天數；0 代表不啟用 TTL 清理。
MEMORY_CAPTURE_L0_L1_RETENTION_DAYS=0

# TDAI Memory extraction
# 是否啟用 L1 structured memory extraction 設定。
MEMORY_EXTRACTION_ENABLED=true
# 是否在 L1 extraction 時做去重/合併。
MEMORY_EXTRACTION_ENABLE_DEDUP=true
# 每個 session 單次 extraction 最多產生的 memory 數。
MEMORY_EXTRACTION_MAX_MEMORIES_PER_SESSION=20
# L1 extraction 專用 model；留空代表使用 TDAI_LLM_MODEL。
MEMORY_EXTRACTION_MODEL=

# TDAI Memory persona/profile
# 每累積多少條 L1 memory 觸發一次 L3 persona/profile generation。
MEMORY_PERSONA_TRIGGER_EVERY_N=50
# L3 profile generation 最多參考的 scene 數。
MEMORY_PERSONA_MAX_SCENES=15
# persona.md 備份保留數。
MEMORY_PERSONA_BACKUP_COUNT=3
# scene block 備份保留數。
MEMORY_PERSONA_SCENE_BACKUP_COUNT=10
# L3 persona/profile 專用 model；留空代表使用 TDAI_LLM_MODEL。
MEMORY_PERSONA_MODEL=

# TDAI Memory pipeline scheduler
# 每個 session 累積多少 completed conversations 後觸發 L1 extraction。
MEMORY_PIPELINE_EVERY_N_CONVERSATIONS=5
# 是否啟用 L1 extraction warmup threshold。
MEMORY_PIPELINE_ENABLE_WARMUP=true
# session 閒置多少秒後觸發 L1 extraction。
MEMORY_PIPELINE_L1_IDLE_TIMEOUT_SECONDS=600
# L1 完成後延遲多少秒才評估/觸發 L2 scene grouping。
MEMORY_PIPELINE_L2_DELAY_AFTER_L1_SECONDS=90
# 同一 agent 兩次 L2 scene grouping 的最短間隔秒數。
MEMORY_PIPELINE_L2_MIN_INTERVAL_SECONDS=900
# 同一 agent 兩次 L2 scene grouping 的最長間隔秒數。
MEMORY_PIPELINE_L2_MAX_INTERVAL_SECONDS=3600
# pipeline state 視為 active session 的時間窗口，單位小時。
MEMORY_PIPELINE_SESSION_ACTIVE_WINDOW_HOURS=24

# TDAI Memory recall
# 是否啟用 auto-recall 設定。
MEMORY_RECALL_ENABLED=true
# 每次 recall 最多返回的 L1 memory 數。
MEMORY_RECALL_MAX_RESULTS=5
# recall 結果最低分數門檻。
MEMORY_RECALL_SCORE_THRESHOLD=0.3
# recall 策略；可用 embedding、keyword、hybrid。
MEMORY_RECALL_STRATEGY=hybrid
# recall timeout，單位毫秒。
MEMORY_RECALL_TIMEOUT_MS=5000

# TDAI Memory BM25
# 是否啟用 BM25/keyword full-text search 設定。
MEMORY_BM25_ENABLED=true
# BM25 tokenization/search 語言；可用 zh 或 en。
MEMORY_BM25_LANGUAGE=zh

# TDAI Memory offload
# 是否啟用 context offload/compression module。
MEMORY_OFFLOAD_ENABLED=false
# offload JSONL 索引檔名。
MEMORY_OFFLOAD_JSONL_FILENAME=offload.jsonl
# offload 原始結果 reference 目錄名。
MEMORY_OFFLOAD_REFS_DIR=refs
# Mermaid flowchart 輸出目錄名。
MEMORY_OFFLOAD_MMDS_DIR=mmds
# 預設 offload compression level；可用 mild、aggressive、emergency。
MEMORY_OFFLOAD_DEFAULT_COMPRESSION_LEVEL=mild
# mild compression 讀取最近多少條 offload entries。
MEMORY_OFFLOAD_MILD_RECENT_ENTRIES=10
# mild compression 中 score 小於等於此值時直接 inline summary。
MEMORY_OFFLOAD_MILD_INLINE_SCORE_THRESHOLD=3
# aggressive compression 讀取最近多少條 offload entries。
MEMORY_OFFLOAD_AGGRESSIVE_RECENT_ENTRIES=15
# emergency compression 讀取最近多少條 offload entries。
MEMORY_OFFLOAD_EMERGENCY_RECENT_ENTRIES=20
# summarizer 處理 tool result 時最多保留的字元數。
MEMORY_OFFLOAD_SUMMARIZER_MAX_RESULT_CHARS=4000
# Mermaid prompt 中每條 entry summary 最多保留的字元數。
MEMORY_OFFLOAD_MERMAID_ENTRY_SUMMARY_CHARS=200
# offload tool_call label 最多保留的字元數。
MEMORY_OFFLOAD_TOOL_CALL_LABEL_CHARS=80

AGENT_HOME_DIR=/mnt/data/misc/agent-server/home
LOG_DIR=/mnt/data/misc/agent-server/log

SANDBOX_ENDPOINT=http://192.168.1.252:8090
SANDBOX_API_KEY=NO_KEY
