DEBUG=true

# PostgreSQL Database (for LangGraph checkpointer)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aiagent
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aiagent
LANGGRAPH_SCHEMA=langgraph

# Qdrant Vector Database (for RAG)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=memories

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:3001
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=my-instance

# i18n locale (default: zh_HK)
LANG_LOCALE=zh_HK

ROUTING_LLM_ENDPOINT=http://localhost:8604/v1
ROUTING_LLM_API_KEY=change-me
ROUTING_LLM_MODEL=qwen3.5-4b

SYS_ACT_LLM_ENDPOINT=http://localhost:8601/v1
SYS_ACT_LLM_API_KEY=change-me
SYS_ACT_LLM_MODEL=gemma4-26b-a4b

EMBEDDING_LLM_ENDPOINT=http://localhost:8605
EMBEDDING_LLM_API_KEY=change-me
EMBEDDING_LLM_MODEL=qwen3-embedding-4b
EMBEDDING_DIMENSION=2560

AGENT_HOME_DIR=/path/to/agent-home
