# Core sandbox provider settings
SANDBOX_PROVIDER=aio
SANDBOX_DEFAULT_PROFILE=default
SANDBOX_IDLE_TIMEOUT_SECONDS=1800

# Local Docker backend
SANDBOX_BACKEND=local_docker
AGENT_HOME_DIR=/mnt/data/misc/agent-server/home
SANDBOX_AGENT_BASE_URL=http://127.0.0.1:8080
SANDBOX_API_TOKEN=replace-with-unique-sandbox-token

